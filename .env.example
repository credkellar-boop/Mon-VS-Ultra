# ==========================================
# Mon-VS-Ultra Environment Configuration
# ==========================================

# Core System
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# AR Spatial Engine & Ephemeral Logic
AR_ENGINE_LICENSE_KEY=your_license_key_here
SPATIAL_RENDER_RESOLUTION=1080p
EPHEMERAL_CACHE_TTL_SECONDS=3600

# Social Distribution Pipelines
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
META_GRAPH_API_TOKEN=your_meta_token
TIKTOK_CLIENT_KEY=your_tiktok_client_key

# Docker Ecosystem & Databases
POSTGRES_USER=monvs_admin
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=monvs_unified
REDIS_URL=redis://localhost:6379

# Storage (AWS S3 for Media Pipelines)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-west-2
MEDIA_BUCKET_NAME=mon-vs-media-dev
